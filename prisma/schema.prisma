generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. Roles and Status setup
enum Role {
  ADMIN
  MEMBER
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

// 2. The Tables
model User {
  id       String @id @default(uuid())
  email    String @unique
  password String // We will store hashed passwords here
  name     String
  role     Role   @default(MEMBER)
  
  projects Project[] // Projects this user manages
  tasks    Task[]    // Tasks assigned to this user
}

model Project {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  
  // Relationship: Who created this project?
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  
  tasks     Task[]
}

model Task {
  id        String     @id @default(uuid())
  title     String
  status    TaskStatus @default(PENDING)
  dueDate   DateTime
  
  // Relationship: Which project is this in?
  projectId String
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Relationship: Who is doing this task?
  assigneeId String? // The "?" means a task doesn't NEED an assignee immediately
  assignee   User?   @relation(fields: [assigneeId], references: [id])
}