---
import { prisma } from '../../../lib/prisma';

const user = Astro.locals.user;

if (!user || user.role !== 'ADMIN') {
  return Astro.redirect('/login');
}

const id = Astro.params.id;

const project = await prisma.project.findUnique({

  where: {
    id
  },

  include: {

    tasks: {

      include: {
        assignee: true
      }

    }

  }

});

if (!project) {
  return Astro.redirect('/admin/projects');
}
---

<html>

<head>

  <title>
    Project Details
  </title>

  <style>

    body {

      margin: 0;

      padding: 40px;

      font-family: Arial;

      background: #f3f4f6;

    }

    .back-btn {

      display: inline-flex;

      align-items: center;

      gap: 8px;

      margin-bottom: 25px;

      background: #2563eb;

      color: white;

      text-decoration: none;

      padding: 12px 22px;

      border-radius: 12px;

      font-weight: 600;

      font-size: 15px;

      transition: 0.2s ease;

      box-shadow:
        0 4px 12px rgba(37,99,235,0.25);

    }

    .back-btn::before {

      content: "←";

      font-size: 16px;

    }

    .back-btn:hover {

      background: #1d4ed8;

      transform: translateY(-1px);

    }

    .project-card {

      background: white;

      padding: 35px;

      border-radius: 24px;

      box-shadow:
        0 5px 20px rgba(0,0,0,0.08);

      margin-bottom: 35px;

    }

    .project-title {

      font-size: 40px;

      margin-bottom: 15px;

      color: #111827;

    }

    .project-description {

      color: #6b7280;

      font-size: 17px;

      line-height: 1.7;

    }

    h2 {

      margin-bottom: 20px;

      color: #111827;

    }

    table {

      width: 100%;

      border-collapse: collapse;

      background: white;

      border-radius: 20px;

      overflow: hidden;

      box-shadow:
        0 5px 20px rgba(0,0,0,0.08);

    }

    th {

      background: #f9fafb;

      padding: 18px;

      text-align: left;

      font-size: 15px;

    }

    td {

      padding: 18px;

      border-top: 1px solid #eee;

    }

    tr:hover {

      background: #f9fafb;

    }

    .badge {

      padding: 8px 14px;

      border-radius: 999px;

      font-size: 13px;

      font-weight: bold;

      display: inline-block;

    }

    .pending {

      background: #fee2e2;

      color: #dc2626;

    }

    .progress {

      background: #fef3c7;

      color: #d97706;

    }

    .completed {

      background: #dcfce7;

      color: #16a34a;

    }

  </style>

</head>

<body>

  <a
    href="/admin/projects"
    class="back-btn"
  >
    Back to Projects
  </a>

  <div class="project-card">

    <div class="project-title">
      {project.name}
    </div>

    <div class="project-description">
      {project.description}
    </div>

  </div>

  <h2>
    Project Tasks
  </h2>

  <table>

    <tr>

      <th>Task</th>

      <th>Assigned To</th>

      <th>Status</th>

    </tr>

    {
      project.tasks.map(task => (

        <tr>

          <td>
            {task.title}
          </td>

          <td>
            {task.assignee.name}
          </td>

          <td>

            {
              task.status === 'PENDING' && (
                <span class="badge pending">
                  PENDING
                </span>
              )
            }

            {
              task.status === 'IN_PROGRESS' && (
                <span class="badge progress">
                  IN PROGRESS
                </span>
              )
            }

            {
              task.status === 'COMPLETED' && (
                <span class="badge completed">
                  COMPLETED
                </span>
              )
            }

          </td>

        </tr>

      ))
    }

  </table>

</body>

</html>